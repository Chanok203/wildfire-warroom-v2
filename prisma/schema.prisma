// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  password  String   // อย่าลืม Hash ก่อนเก็บนะครับ
  createdAt DateTime @default(now())
}

model ApiKey {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String?  // เอาไว้ระบุว่าเป็น Key ของใคร หรือใช้ทำอะไร
  isActive    Boolean  @default(true)
  
  // เก็บไว้ดูประวัติเบื้องต้น
  createdAt   DateTime @default(now())
  lastUsedAt  DateTime? 

  @@index([key])
}

model Forecast {
  id         String     @id
  name       String
  droneName  String     @map("drone_name")
  aiStatus   AIStatus   @default(PENDING) @map("ai_status")
  pushStatus PushStatus @default(IDLE) @map("push_status")
  latitude   Float
  longitude  Float
  startTime  DateTime?  @map("start_time")
  inputData  Json?      @map("input_data")
  createdAt  DateTime   @default(now()) @map("created_at")
  updatedAt  DateTime   @updatedAt @map("updated_at")

  results ForecastResult[]

  @@index([id])
  @@map("forecast")
}

model ForecastResult {
  id          String   @id @default(uuid())
  forecastId  String   @map("forecast_id")
  forecast    Forecast @relation(fields: [forecastId], references: [id], onDelete: Cascade)
  filename    String
  minutes     Int
  validAt     DateTime @map("valid_at")
  geojsonData Json     @map("geojson_data")

  @@map("forecast_result")
}

enum AIStatus {
  PENDING
  CREATE_INPUT
  IN_QUEUE
  PROCESSING
  COMPLETED
  FAILED
  CANCELED
}

enum PushStatus {
  IDLE
  PENDING
  PUSHING
  PUSHED
  FAILED
  CANCELED
}
