{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "types": [
      "node"
    ],
    "target": "ES2022",
    "module": "CommonJS",
    "outDir": "./dist",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@shared/*": [
        "src/shared/*"
      ],
      "@modules/*": [
        "src/modules/*"
      ],
      "@generated/*": [
        "generated/*"
      ]
    },
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": [
    "src",
    "prisma.config.ts",
    "generated"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}